{
  "project": "python-dap",
  "description": "Python bindings for DAP SDK with high-level object-oriented API",
  "version": "3.0.0",
  "repository": "https://gitlab.demlabs.net/dap/python-dap",
  
  "architecture": {
    "low_level": {
      "description": "C extension module (python_dap.so) - direct bindings to DAP SDK",
      "location": "src/python_dap*.c",
      "purpose": "Low-level C API exposure to Python",
      "usage": "Internal use only, not for direct application development"
    },
    
    "high_level": {
      "description": "High-level Python API (src/dap/) - object-oriented wrapper around C bindings",
      "location": "src/dap/**/*.py",
      "purpose": "Production-ready API for application development",
      "usage": "Recommended for all applications",
      "style": "Pythonic, OOP, context managers, type hints"
    }
  },
  
  "api_modules": {
    "core": {
      "path": "src/dap/core/",
      "description": "Core system initialization and coordination",
      "main_classes": [
        {
          "name": "Dap",
          "file": "dap.py",
          "description": "Central coordinator for all DAP subsystems",
          "features": ["Singleton pattern", "Context manager", "Subsystem initialization"]
        },
        {
          "name": "DapLogging",
          "file": "logging.py", 
          "description": "Logging system wrapper",
          "features": ["Log levels", "Python logging integration"]
        },
        {
          "name": "DapTime",
          "file": "time.py",
          "description": "Time utilities",
          "features": ["Timestamps", "Formatting", "High-precision timing"]
        },
        {
          "name": "DapSystem",
          "file": "system.py",
          "description": "System resource monitoring",
          "features": ["CPU stats", "Memory stats", "Uptime"]
        },
        {
          "name": "DapType",
          "file": "types.py",
          "description": "Type conversion utilities",
          "features": ["C type conversions", "Python type mappings"]
        }
      ],
      "complexity": "basic",
      "dependencies": []
    },
    
    "crypto": {
      "path": "src/dap/crypto/",
      "description": "Cryptographic operations with high-level API",
      "main_classes": [
        {
          "name": "DapKey",
          "file": "keys.py",
          "description": "Cryptographic key management",
          "features": [
            "Key generation (all algorithms)",
            "Key serialization/deserialization",
            "Quick encrypt/decrypt helpers",
            "Context manager support",
            "Key type validation"
          ],
          "supported_algorithms": [
            "DILITHIUM (recommended)",
            "FALCON",
            "SPHINCSPLUS",
            "CHIPMUNK",
            "KYBER512",
            "IAES (symmetric)",
            "And 40+ more algorithms"
          ]
        },
        {
          "name": "DapSign",
          "file": "sign.py",
          "description": "Unified signature system",
          "features": [
            "Single-key signatures",
            "Multi-key signatures",
            "Aggregated signatures (Chipmunk)",
            "Signature verification",
            "Metadata and compatibility checks"
          ],
          "methods": [
            "sign() - Create signature",
            "verify() - Verify signature",
            "aggregate() - Combine multiple signatures",
            "get_metadata() - Signature information"
          ]
        },
        {
          "name": "DapHash",
          "file": "hash.py",
          "description": "Hashing operations",
          "features": ["SHA3", "Keccak", "Fast hashing", "Hash comparison"]
        },
        {
          "name": "DapCert",
          "file": "cert.py",
          "description": "Certificate management",
          "features": ["Certificate generation", "Certificate signing", "Certificate validation"]
        },
        {
          "name": "DapKeyManager",
          "file": "keys.py",
          "description": "Centralized key storage",
          "features": ["Key caching", "Key reuse", "Memory management"]
        }
      ],
      "complexity": "intermediate",
      "dependencies": ["core"]
    },
    
    "events": {
      "path": "src/dap/events/",
      "description": "Asynchronous I/O and event system",
      "main_classes": [
        {
          "name": "DapEvent",
          "file": "events.py",
          "description": "Event handling system",
          "features": ["Event registration", "Event emission", "Callback management"]
        },
        {
          "name": "DapEventManager",
          "file": "events.py",
          "description": "Event loop manager",
          "features": ["Worker threads", "Event queue", "Async operations"]
        },
        {
          "name": "DapWorker",
          "file": "events.py",
          "description": "Worker thread abstraction",
          "features": ["Task queue", "Thread pool", "Load balancing"]
        },
        {
          "name": "DapContext",
          "file": "events.py",
          "description": "Execution context",
          "features": ["Context management", "Resource cleanup", "Lifecycle hooks"]
        }
      ],
      "complexity": "intermediate",
      "dependencies": ["core"]
    },
    
    "network": {
      "path": "src/dap/network/",
      "description": "Network operations and protocols",
      "main_classes": [
        {
          "name": "DapServer",
          "file": "server.py",
          "description": "Network server",
          "features": ["TCP/UDP servers", "Event-driven I/O", "Worker threads"]
        },
        {
          "name": "DapClient",
          "file": "client.py",
          "description": "Network client",
          "features": ["TCP/UDP clients", "Connection management", "Async operations"]
        },
        {
          "name": "DapHttp",
          "file": "http.py",
          "description": "HTTP protocol support",
          "features": ["HTTP server", "HTTP client", "Request handling"]
        },
        {
          "name": "DapStream",
          "file": "stream.py",
          "description": "Stream protocol",
          "features": ["Sessions", "Channels", "Encrypted streams"]
        },
        {
          "name": "DapNet",
          "file": "net.py",
          "description": "Low-level networking utilities",
          "features": ["Socket operations", "Address management"]
        }
      ],
      "complexity": "advanced",
      "dependencies": ["core", "crypto", "events"]
    },
    
    "global_db": {
      "path": "src/dap/global_db/",
      "description": "Distributed key-value database",
      "main_classes": [
        {
          "name": "DapGlobalDB",
          "file": "gdb.py",
          "description": "Global database interface",
          "features": [
            "Key-value operations (set/get/del)",
            "Group management",
            "MDBX backend",
            "Distributed synchronization",
            "Transaction support"
          ]
        }
      ],
      "complexity": "intermediate",
      "dependencies": ["core", "network"]
    },
    
    "config": {
      "path": "src/dap/config/",
      "description": "Configuration management",
      "main_classes": [
        {
          "name": "DapConfig",
          "file": "config.py",
          "description": "Configuration file parser",
          "features": ["INI-style config", "Type conversion", "Default values"]
        },
        {
          "name": "DapConfigValidator",
          "file": "config_validator.py",
          "description": "Configuration validation",
          "features": ["Schema validation", "Type checking", "Required fields"]
        },
        {
          "name": "DapConfigFile",
          "file": "config_file.py",
          "description": "Config file operations",
          "features": ["File loading", "File saving", "Path management"]
        }
      ],
      "complexity": "basic",
      "dependencies": ["core"]
    },
    
    "common": {
      "path": "src/dap/common/",
      "description": "Common utilities",
      "main_classes": [
        {
          "name": "DapEvents",
          "file": "events.py",
          "description": "Event loop management",
          "features": ["Event handlers", "Callbacks", "Async operations"]
        }
      ],
      "complexity": "advanced",
      "dependencies": ["core"]
    },
    
    "common": {
      "path": "src/dap/common/",
      "description": "Common utilities and types",
      "main_classes": [
        {
          "name": "DapJsonUtils",
          "file": "json_utils.py",
          "description": "JSON utilities",
          "features": ["JSON parsing", "JSON generation"]
        },
        {
          "name": "DapParsers",
          "file": "parsers.py",
          "description": "Data parsers",
          "features": ["Address parsing", "Data format conversion"]
        }
      ],
      "complexity": "basic",
      "dependencies": []
    }
  },
  
  "key_features": {
    "pythonic_api": {
      "description": "High-level Python API following Python best practices",
      "features": [
        "Context managers (with statement)",
        "Type hints",
        "Enums for constants",
        "Exception handling",
        "Property decorators",
        "Dataclasses"
      ]
    },
    
    "smart_defaults": {
      "description": "Sensible defaults for all operations",
      "examples": [
        "Default key type: DILITHIUM (post-quantum secure)",
        "Default hash type: SHA3",
        "Automatic resource cleanup",
        "Optional parameters with smart detection"
      ]
    },
    
    "error_handling": {
      "description": "Comprehensive error handling with custom exceptions",
      "exceptions": [
        "DapException - Base exception",
        "DapKeyError - Key operation errors",
        "DapSignError - Signature operation errors",
        "DapInitializationError - Initialization errors"
      ]
    },
    
    "memory_management": {
      "description": "Automatic memory management",
      "features": [
        "Python garbage collection",
        "Context manager cleanup",
        "RAII pattern",
        "No manual memory management required"
      ]
    }
  },
  
  "usage_patterns": {
    "basic_initialization": {
      "description": "Initialize DAP SDK with context manager",
      "code": "with Dap() as dap:\n    # All systems initialized\n    pass  # Automatic cleanup"
    },
    
    "key_generation": {
      "description": "Generate cryptographic keys",
      "code": "from dap.crypto import DapKey, DapKeyType\n\nkey = DapKey(DapKeyType.DILITHIUM)\n# Use key...\nkey.close()  # Or use context manager"
    },
    
    "signature_workflow": {
      "description": "Sign and verify data",
      "code": "from dap.crypto import DapSign, DapKey\n\nkey = DapKey()\nsignature = DapSign.sign(b'data', pvt_key=key)\nis_valid = DapSign.verify(signature, key.get_public_key())"
    },
    
    "multi_signature": {
      "description": "Create multi-signature",
      "code": "from dap.crypto import DapSign\n\nkeys = [DapKey() for _ in range(3)]\nsignature = DapSign.sign(b'data', pvt_keys=keys)"
    },
    
    "database_operations": {
      "description": "Use Global DB",
      "code": "from dap.global_db import DapGlobalDB\n\ndb = DapGlobalDB('/path/to/db')\ndb.set('group', 'key', b'value')\nvalue = db.get('group', 'key')\ndb.close()"
    }
  },
  
  "documentation_status": {
    "api_reference": "pending",
    "class_documentation": "pending",
    "method_documentation": "pending",
    "examples": "in_progress",
    "tutorials": "pending"
  },
  
  "best_practices": [
    "Always use context managers (with statement) for resource management",
    "Use DILITHIUM for post-quantum security (default)",
    "Handle DapException and its subclasses",
    "Close resources explicitly if not using context managers",
    "Use DapKeyManager for key caching",
    "Prefer high-level API (src/dap/) over low-level C bindings",
    "Check is_post_quantum property for quantum safety",
    "Use type hints for better IDE support"
  ],
  
  "migration_from_c_api": {
    "description": "Migrating from direct C API usage to high-level Python API",
    "mappings": {
      "dap_sdk_init()": "with Dap() as dap:",
      "dap_enc_key_new()": "DapKey(DapKeyType.DILITHIUM)",
      "dap_sign_create()": "DapSign.sign(data, pvt_key=key)",
      "dap_hash_fast()": "DapHash.fast(data)",
      "dap_global_db_set()": "db.set(group, key, value)"
    }
  }
}
