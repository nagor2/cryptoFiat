{
  "name": "OpenEvolve Integration Module",
  "version": "1.0.0",
  "type": "integration_module",
  "created": "2025-01-16T00:00:00Z",
  "description": "Complete integration system for Smart Layered Context with OpenEvolve evolutionary code optimization",
  "integration_phases": {
    "phase_1": {
      "name": "Setup + Optimization",
      "status": "implemented",
      "description": "Basic handoff between SLC and OpenEvolve with project setup and result integration",
      "priority": "high",
      "files": [
        "tools/integrations/openevolve/setup_optimization.py",
        "tools/integrations/openevolve/handoff_manager.py",
        "tools/integrations/openevolve/result_processor.py"
      ],
      "templates": [
        "templates/openevolve/phase1_setup_template.json",
        "templates/openevolve/phase1_optimization_template.json"
      ],
      "cli_commands": [
        "evolve-setup",
        "evolve-optimize",
        "evolve-integrate"
      ]
    },
    "phase_2": {
      "name": "Templates + Generation",
      "status": "implemented", 
      "description": "Template-driven evolution with intelligent template selection and multi-template fusion",
      "priority": "medium",
      "files": [
        "tools/integrations/openevolve/template_evolver.py",
        "tools/integrations/openevolve/template_selector.py",
        "tools/integrations/openevolve/multi_template_fusion.py"
      ],
      "templates": [
        "templates/openevolve/phase2_template_selection.json",
        "templates/openevolve/phase2_fusion_strategy.json",
        "templates/openevolve/phase2_evolution_config.json"
      ],
      "cli_commands": [
        "evolve-template",
        "evolve-fusion",
        "evolve-select"
      ]
    },
    "phase_3": {
      "name": "Context + Pipeline",
      "status": "implemented",
      "description": "Deep context integration with reflection-aware evolution and seamless workflow",
      "priority": "low",
      "files": [
        "tools/integrations/openevolve/context_aware_evolver.py",
        "tools/integrations/openevolve/reflection_integration.py",
        "tools/integrations/openevolve/seamless_workflow.py"
      ],
      "templates": [
        "templates/openevolve/phase3_context_integration.json",
        "templates/openevolve/phase3_reflection_system.json",
        "templates/openevolve/phase3_workflow_engine.json"
      ],
      "cli_commands": [
        "evolve-context",
        "evolve-reflect",
        "evolve-workflow"
      ]
    }
  },
  "configuration": {
    "openevolve_path": "openevolve/",
    "integration_mode": "phase_1",
    "auto_handoff": true,
    "context_sync": true,
    "template_awareness": true,
    "reflection_integration": true,
    "checkpoint_management": true
  },
  "dependencies": {
    "openevolve": ">=0.0.10",
    "pyyaml": ">=6.0",
    "asyncio": "builtin",
    "pathlib": "builtin"
  },
  "commands": {
    "evolve": {
      "description": "Start OpenEvolve integration with current context",
      "cli_equivalent": "./slc evolve [options]",
      "usage": "evolve [template] [project_name] [--iterations N] [--config path]"
    },
    "evolve-setup": {
      "description": "Phase 1: Setup project and run optimization",
      "cli_equivalent": "./slc evolve-setup [template] [project_name]",
      "usage": "evolve-setup [template] [project_name] [--iterations N]"
    },
    "evolve-template": {
      "description": "Phase 2: Template-driven evolution",
      "cli_equivalent": "./slc evolve-template [template] [project_name]",
      "usage": "evolve-template [template] [project_name] [--fusion]"
    },
    "evolve-context": {
      "description": "Phase 3: Context-aware evolution",
      "cli_equivalent": "./slc evolve-context [task_description]",
      "usage": "evolve-context [task_description] [--reflection]"
    },
    "evolve-status": {
      "description": "Check evolution status and results",
      "cli_equivalent": "./slc evolve-status",
      "usage": "evolve-status [--detailed] [--checkpoint N]"
    }
  },
  "templates": {
    "phase1": {
      "setup": "templates/openevolve/phase1_setup_template.json",
      "optimization": "templates/openevolve/phase1_optimization_template.json",
      "integration": "templates/openevolve/phase1_integration_template.json"
    },
    "phase2": {
      "selection": "templates/openevolve/phase2_template_selection.json",
      "fusion": "templates/openevolve/phase2_fusion_strategy.json",
      "evolution": "templates/openevolve/phase2_evolution_config.json"
    },
    "phase3": {
      "context": "templates/openevolve/phase3_context_integration.json",
      "reflection": "templates/openevolve/phase3_reflection_system.json",
      "workflow": "templates/openevolve/phase3_workflow_engine.json"
    }
  },
  "navigation_system": {
    "purpose": "OpenEvolve Integration Module - Central coordination for SLC-OpenEvolve integration",
    "recovery_path": ".context/manifest.json",
    "current_file": ".context/modules/integrations/openevolve_integration.json",
    "file_role": "INTEGRATION_MODULE",
    "related_files": [
      ".context/tools/integrations/openevolve/",
      ".context/templates/openevolve/",
      ".context/modules/core/manifest.json"
    ],
    "quick_navigation": {
      "🏠 Главная": ".context/manifest.json - главный навигатор системы",
      "🔄 Интеграция": ".context/tools/integrations/openevolve/ - файлы интеграции",
      "📋 CLI": ".context/tools/scripts/slc_cli.py - команды интеграции",
      "📄 Шаблоны": ".context/templates/openevolve/ - шаблоны интеграции"
    },
    "usage_hint": "./slc evolve [template] [project_name] для запуска интеграции",
    "ai_context": "Модуль интеграции OpenEvolve: openevolve_integration.json"
  }
} 