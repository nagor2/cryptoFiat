{
  "name": "Phase 3 Context Integration Template",
  "version": "1.0.0",
  "type": "openevolve_integration_template",
  "phase": "phase_3",
  "category": "context_integration",
  "created": "2025-01-16T00:00:00Z",
  "description": "Template for Phase 3: Deep context integration with reflection-aware evolution and seamless workflow",
  "domain": "integration",
  "language": "python",
  "complexity": "very_high",
  "framework": "openevolve",
  "performance": "intelligent",
  "integrations": ["slc", "openevolve", "python", "ai_ml", "reflection"],
  "requirements": {
    "slc_version": ">=4.3.0",
    "openevolve_version": ">=0.0.10",
    "python_version": ">=3.9",
    "dependencies": ["pyyaml", "asyncio", "pathlib", "numpy", "scikit-learn", "reflection_engine"]
  },
  "architecture": {
    "context_integration_pipeline": {
      "context_loading": {
        "description": "Load and analyze SLC context for evolution",
        "components": ["context_loader", "context_analyzer", "context_enhancer"]
      },
      "reflection_integration": {
        "description": "Integrate reflection system with evolution",
        "components": ["reflection_engine", "insight_extractor", "learning_integrator"]
      },
      "seamless_workflow": {
        "description": "Seamless workflow orchestration",
        "components": ["workflow_orchestrator", "state_manager", "continuity_handler"]
      }
    }
  },
  "workflow": {
    "steps": [
      {
        "step": 1,
        "name": "Context Analysis",
        "description": "Analyze current SLC context and extract relevant information",
        "command": "./slc evolve-analyze-context {task_description}",
        "output": "context_analyzed"
      },
      {
        "step": 2,
        "name": "Reflection Integration",
        "description": "Integrate reflection insights into evolution process",
        "command": "./slc evolve-integrate-reflection {task_description}",
        "output": "reflection_integrated"
      },
      {
        "step": 3,
        "name": "Context-Aware Evolution",
        "description": "Run evolution with full context awareness",
        "command": "./slc evolve-context-aware {task_description}",
        "output": "evolution_completed"
      }
    ]
  },
  "navigation_system": {
    "purpose": "Phase 3 Context Integration Template - Deep context integration with reflection-aware evolution",
    "recovery_path": ".context/modules/integrations/openevolve_integration.json",
    "current_file": ".context/templates/openevolve/phase3_context_integration.json",
    "file_role": "INTEGRATION_TEMPLATE",
    "related_files": [
      ".context/templates/openevolve/phase3_reflection_system.json",
      ".context/templates/openevolve/phase3_workflow_engine.json"
    ],
    "quick_navigation": {
      "🏠 Главная": ".context/modules/integrations/openevolve_integration.json",
      "🧠 Рефлексия": ".context/templates/openevolve/phase3_reflection_system.json",
      "🔄 Workflow": ".context/templates/openevolve/phase3_workflow_engine.json",
      "📋 CLI": "./slc evolve-context [task_description]"
    },
    "usage_hint": "./slc evolve-context [task_description] для контекстно-осведомленной эволюции",
